// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/python
{
	"name": "Foundry Hosted Agent Quickstart - Python",
	"dockerFile": "Dockerfile",
	"features": {
		"azure-cli": "latest"
	},
	"forwardPorts": [8088],
	"portsAttributes": {
		"8088": {
			"label": "Foundry Hosted Agent",
			"onAutoForward": "notify"
		}
	},
	"postCreateCommand": "bash -c 'echo \"export PROMPT_DIRTRIM=1\" >> ~/.bashrc || true; azd ext install microsoft.foundry || true; cat .devcontainer/first-run-notice.txt || echo \"Setup completed\"'",
	"customizations": {
		"vscode": {
			"extensions": [
				"ms-python.python",
				"ms-python.debugpy",
				"ms-python.vscode-python-envs",
				"ms-azuretools.vscode-docker",
				"ms-azuretools.azure-ai-foundry",
				"GitHub.copilot",
				"humao.rest-client"
			]
		}
	},
	"remoteUser": "vscode",
	"shutdownAction": "stopContainer"
}
