# Microsoft Foundry hosted agent configuration
# Copy this file to .env and fill in your values

FOUNDRY_PROJECT_ENDPOINT="https://<your-ai-services>.services.ai.azure.com/api/projects/<your-project-name>"
AZURE_AI_MODEL_DEPLOYMENT_NAME="gpt-5-mini"

# Optional GitHub configuration for the daily digest automation.
GITHUB_REPOSITORY="Azure/azure-functions-host"
# Set GITHUB_TOKEN only if you want higher public GitHub API rate limits.
GITHUB_TOKEN=""
